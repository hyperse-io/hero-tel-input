{
  "name": "@hyperse/hero-tel-input-website",
  "version": "0.0.5",
  "description": "Hero Tel Input Website",
  "private": true,
  "homepage": "https://github.com/hyperse-io/hero-tel-input#readme",
  "bugs": {
    "url": "https://github.com/hyperse-io/hero-tel-input/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:hyperse-io/hero-tel-input.git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "next build && yarn postbuild",
    "postbuild": "next-sitemap && pagefind --site .next/server/app --output-path public/_pagefind",
    "build:ghpage": "cross-env NEXT_BUILD_ENV_OUTPUT='export' next build && yarn postbuild:ghpage",
    "postbuild:ghpage": "next-sitemap && pagefind --site .next/server/app --output-path out/_pagefind",
    "dev": "next dev -p 3000 -H 0.0.0.0",
    "fix-all-files": "eslint . --fix",
    "g:lint-staged-files": "lint-staged --allow-empty",
    "lint": "eslint .",
    "start": "next start -p 3000 -H 0.0.0.0",
    "test": "vitest run",
    "typecheck": "tsc --project ./tsconfig.json --noEmit"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "@heroui/react": "^3.2.0",
    "@hyperse/hero-tel-input": "workspace:*",
    "@iconify/react": "^6.0.2",
    "@lottiefiles/dotlottie-react": "^0.19.4",
    "@tailwindcss/typography": "^0.5.20",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "next": "^16.2.9",
    "nextra": "^4.6.1",
    "nextra-theme-docs": "^4.6.1",
    "postcss": "^8.5.15",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-react-aria-components": "^2.1.1"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@hyperse/eslint-config-hyperse": "^1.7.3",
    "@hyperse/next-config": "^1.0.7",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "commitizen": "^4.3.2",
    "cross-env": "^10.1.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.5.0",
    "lint-staged": "^17.0.7",
    "next-sitemap": "^4.2.3",
    "pagefind": "^1.5.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "zod": "4.4.3"
  }
}
