{
  "name": "@hyperse/hero-tel-input",
  "version": "1.0.3",
  "description": "A hero-ui tel input component",
  "homepage": "https://github.com/hyperse-io/hero-tel-input",
  "repository": {
    "type": "git",
    "url": "https://github.com/hyperse-io/hero-tel-input",
    "directory": "packages/hero-tel-input"
  },
  "author": {
    "name": "Hyperse",
    "url": "https://github.com/hyperse-io"
  },
  "type": "module",
  "license": "SEE LICENSE IN FILE 'LICENSE'",
  "keywords": [
    "heroui",
    "hero-tel-input",
    "typescript",
    "react"
  ],
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "./bin/",
    "./dist/",
    "./index.js"
  ],
  "workspaces": [
    "./",
    "website",
    "examples/example-nextjs"
  ],
  "scripts": {
    "build": "tsdown",
    "build-website": "yarn workspace @hyperse/hero-tel-input-website run build:ghpage",
    "lint": "eslint .",
    "lint-fix": "yarn lint --fix",
    "test": "run-s test-unit",
    "test-unit": "vitest run",
    "typecheck": "tsc --project ./tsconfig.json --noEmit",
    "lint-staged-files": "lint-staged --allow-empty",
    "changeset": "changeset",
    "release": "yarn build && changeset publish",
    "cz": "cz",
    "prepare": "husky"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  },
  "dependencies": {
    "libphonenumber-js": "^1.13.6",
    "react-aria-components": "^1.18.0",
    "usehooks-ts": "^3.1.1"
  },
  "devDependencies": {
    "@changesets/changelog-github": "0.7.0",
    "@changesets/cli": "2.31.0",
    "@commitlint/cli": "21.0.2",
    "@commitlint/config-conventional": "21.0.2",
    "@heroui/react": "^3.2.0",
    "@hyperse/eslint-config-hyperse": "^1.7.3",
    "@hyperse/exec-program": "^1.2.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "commitizen": "4.3.2",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "^10.5.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.7",
    "npm-run-all": "^4.1.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "unrun": "^0.3.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "@heroui/react": ">=3.2.0",
    "react": ">=19.2.7",
    "react-dom": ">=19.2.7",
    "tailwindcss": ">=4.3.1"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "yarn@4.9.2",
  "resolutions": {
    "zod": "4.3.6"
  }
}
